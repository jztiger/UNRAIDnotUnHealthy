# Copy to .env on the Unraid host (gitignored). docker compose picks it
# up automatically; the values flow into the container as env vars.

# Sonarr (TV) — leave SONARR_API_KEY blank to skip the exporter
SONARR_URL=http://192.168.1.21:8989
SONARR_API_KEY=

# Radarr (Movies) — leave RADARR_API_KEY blank to skip the exporter
RADARR_URL=http://192.168.1.6:7878
RADARR_API_KEY=

# Prometheus remote-write basic auth — the Raspberry Pi closet collector pushes
# UP-Sense metrics here. Leave the bcrypt blank to keep Prometheus open (no
# auth). Generate the hash with `htpasswd -nBC 10 closet-pi` and copy the part
# AFTER the colon (see pi/README.md). PROM_BASIC_AUTH_PASSWORD is the plaintext
# Grafana sends + the self-scrape password; it must be the password that hashes
# to PROMETHEUS_REMOTE_WRITE_PASSWORD_BCRYPT. Username is fixed at closet-pi.
PROMETHEUS_REMOTE_WRITE_PASSWORD_BCRYPT=
PROM_BASIC_AUTH_PASSWORD=

# AC Infinity Controller 69 Pro (cloud API) — leave ACINFINITY_PASSWORD blank to
# skip. NOTE: AC Infinity's API is plain HTTP (no TLS); use a dedicated account.
ACINFINITY_EMAIL=
ACINFINITY_PASSWORD=

# Optional overrides
# TZ=America/Los_Angeles
# PROMETHEUS_RETENTION=30d
# LOKI_RETENTION=14d
# GF_SECURITY_ADMIN_PASSWORD=
