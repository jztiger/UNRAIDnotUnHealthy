# Copy to .env on the Unraid host (gitignored). docker compose picks it
# up automatically; the values flow into the container as env vars.

# Sonarr (TV) — leave SONARR_API_KEY blank to skip the exporter
SONARR_URL=http://192.168.1.21:8989
SONARR_API_KEY=

# Radarr (Movies) — leave RADARR_API_KEY blank to skip the exporter
RADARR_URL=http://192.168.1.6:7878
RADARR_API_KEY=

# Optional overrides
# TZ=America/Los_Angeles
# PROMETHEUS_RETENTION=30d
# LOKI_RETENTION=14d
# GF_SECURITY_ADMIN_PASSWORD=
