{
  "title": "DNS Health & Troubleshooting",
  "uid": "unhealthy-dns",
  "tags": ["unraid", "unhealthy", "network", "dns"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "lan_filter",
        "type": "textbox",
        "label": "LAN IP filter (regex, blank=all)",
        "current": { "selected": false, "text": "", "value": "" }
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 100, "type": "text", "title": "",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 3 },
      "options": {
        "mode": "markdown",
        "content": "**Two views combined.** *Active probes* (top half) actively query each resolver every 30–60s from this Unraid box; failures and slow responses are visible in real time. *BGW drops* (bottom half) show DNS the router blocked — the smoking gun if your LAN devices were denied. Use them together: active probe failing + BGW drop = router blocking; active probe failing + no BGW drop = upstream/resolver issue."
      }
    },
    {
      "id": 200, "type": "stat", "title": "Resolvers up (active probe)",
      "description": "Count of DNS resolvers currently responding to A-record probes. Anything less than total = something's broken right now.",
      "gridPos": { "x": 0, "y": 3, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A",
        "expr": "sum(probe_success{job=\"dns_probe_a\"})",
        "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 1 },
          { "color": "green", "value": 4 }
        ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 201, "type": "stat", "title": "Avg resolution time",
      "description": "Average DNS A-record resolution latency across all probed resolvers (lower = better). Sudden jumps usually mean an upstream is slow.",
      "gridPos": { "x": 6, "y": 3, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A",
        "expr": "avg(probe_dns_lookup_time_seconds{job=\"dns_probe_a\"})",
        "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } }],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 0.1 },
          { "color": "red", "value": 0.5 }
        ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 202, "type": "stat", "title": "BGW DNS drops (window)",
      "description": "Number of DNS packets the BGW dropped in the dashboard time window. Non-zero = look at the LAN drops table below to find the affected device.",
      "gridPos": { "x": 12, "y": 3, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "unhealthy-loki" },
      "targets": [{ "refId": "A",
        "expr": "sum(count_over_time({host=\"att-router\"} |~ \"hook=FORWARD\" |~ \"DPT=53|DPT=853\" [$__range]))",
        "datasource": { "type": "loki", "uid": "unhealthy-loki" } }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 1 },
          { "color": "red", "value": 100 }
        ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 203, "type": "stat", "title": "NXDOMAIN behavior correct",
      "description": "Resolvers that correctly return NXDOMAIN for a non-existent domain. If less than total, a resolver is synthesizing responses (captive portal, ad-blocker injecting an A record, ISP redirect to ad page).",
      "gridPos": { "x": 18, "y": 3, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A",
        "expr": "sum(probe_success{job=\"dns_probe_nxdomain\"})",
        "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 1 },
          { "color": "green", "value": 4 }
        ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 210, "type": "timeseries", "title": "Probe success per resolver (1=up, 0=down)",
      "description": "Active DNS A-record probe result over time. Drops to 0 are exactly when that resolver failed for you. Compare resolvers — if only the BGW (.254) fails while public ones stay up, the BGW's resolver is the issue. If all fail simultaneously, your WAN is down.",
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A",
        "expr": "probe_success{job=\"dns_probe_a\"}",
        "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
        "legendFormat": "{{resolver}}" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "pointSize": 4 }, "min": 0, "max": 1, "decimals": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 211, "type": "timeseries", "title": "Resolution time per resolver",
      "description": "How long each resolver takes to answer. Spikes correlate with slow upstream paths or congestion. A resolver that climbs steadily over time often means it's about to fail.",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A",
        "expr": "probe_dns_lookup_time_seconds{job=\"dns_probe_a\"}",
        "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
        "legendFormat": "{{resolver}}" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }, "unit": "s", "decimals": 3 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 220, "type": "table", "title": "Resolver status snapshot",
      "description": "Current health of every probed resolver across all probe types (A / AAAA / alt-domain / NXDOMAIN). One ROW per probe-type+resolver. Quick way to see which combinations are healthy.",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A",
        "expr": "probe_success{job=~\"dns_probe_.*\"}",
        "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
        "instant": true, "format": "table" }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true }, "renameByName": { "job": "Probe", "resolver": "Resolver", "Value": "Up" } } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [{ "field": "Up", "desc": false }, { "field": "Resolver", "desc": false }] } }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [
        { "matcher": { "id": "byName", "options": "Up" },
          "properties": [
            { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ] } }
          ] }
      ] },
      "options": { "showHeader": true }
    },
    {
      "id": 221, "type": "table", "title": "Avg resolution time per resolver (last hour)",
      "description": "Sustained latency comparison. Sort the column to see the fastest path you have available — useful if you're considering changing your LAN's preferred DNS.",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A",
        "expr": "avg_over_time(probe_dns_lookup_time_seconds{job=\"dns_probe_a\"}[1h])",
        "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
        "instant": true, "format": "table" }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true }, "renameByName": { "resolver": "Resolver", "Value": "Avg latency (s)" } } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [{ "field": "Avg latency (s)", "desc": false }] } }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "left" }, "decimals": 4 }, "overrides": [
        { "matcher": { "id": "byName", "options": "Avg latency (s)" },
          "properties": [
            { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
            { "id": "unit", "value": "s" },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ] } }
          ] }
      ] },
      "options": { "showHeader": true }
    },
    {
      "id": 250, "type": "text", "title": "",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 2 },
      "options": {
        "mode": "markdown",
        "content": "**Below: BGW-blocked DNS** (firewall events, not probes). Empty = the BGW isn't blocking anything. Non-empty + your LAN device's IP appearing = the smoking gun."
      }
    },
    {
      "id": 1, "type": "stat", "title": "DNS packets blocked (window)",
      "gridPos": { "x": 0, "y": 28, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "unhealthy-loki" },
      "targets": [{ "refId": "A",
        "expr": "sum(count_over_time({host=\"att-router\"} |~ \"DPT=53|DPT=853\" [$__range]))",
        "datasource": { "type": "loki", "uid": "unhealthy-loki" } }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2, "type": "stat", "title": "LAN→WAN DNS blocked",
      "description": "Your devices trying to do DNS and being blocked. ANY non-zero number here is worth investigating — these are probably the cause of your DNS issues.",
      "gridPos": { "x": 6, "y": 28, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "unhealthy-loki" },
      "targets": [{ "refId": "A",
        "expr": "sum(count_over_time({host=\"att-router\"} |~ \"hook=FORWARD\" |~ \"DPT=53|DPT=853\" [$__range]))",
        "datasource": { "type": "loki", "uid": "unhealthy-loki" } }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 1 },
          { "color": "orange", "value": 50 },
          { "color": "red", "value": 500 }
        ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3, "type": "stat", "title": "Affected LAN devices",
      "description": "Distinct internal source IPs that had a DNS packet dropped. If your DNS issues correlate with one device's IP, this points right at it.",
      "gridPos": { "x": 12, "y": 28, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "unhealthy-loki" },
      "targets": [{ "refId": "A",
        "expr": "count(count by (src) (count_over_time({host=\"att-router\"} |~ \"hook=FORWARD\" |~ \"DPT=53|DPT=853\" |~ \"$lan_filter\" | regexp `SRC=(?P<src>[^ ]+)` [$__range])))",
        "datasource": { "type": "loki", "uid": "unhealthy-loki" } }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4, "type": "stat", "title": "DNS drops / min (last 5m)",
      "description": "Recent DNS-drop rate. Non-zero = the BGW is actively blocking DNS right now.",
      "gridPos": { "x": 18, "y": 28, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "unhealthy-loki" },
      "targets": [{ "refId": "A",
        "expr": "sum(count_over_time({host=\"att-router\"} |~ \"DPT=53|DPT=853\" [5m])) / 5",
        "datasource": { "type": "loki", "uid": "unhealthy-loki" } }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 0.1 },
          { "color": "red", "value": 5 }
        ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 10, "type": "timeseries", "title": "DNS drops per minute (LAN→WAN)",
      "description": "Time series of LAN-originated DNS drops. Spikes correlate with DNS outages your devices experienced. If this lines up with the times you've been losing DNS, the BGW is blocking.",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "unhealthy-loki" },
      "targets": [{ "refId": "A",
        "expr": "sum by (dpt) (count_over_time({host=\"att-router\"} |~ \"hook=FORWARD\" |~ \"DPT=53|DPT=853\" |~ \"$lan_filter\" | regexp `DPT=(?P<dpt>[^ ]+)` [1m]))",
        "datasource": { "type": "loki", "uid": "unhealthy-loki" },
        "legendFormat": "port {{dpt}}" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 25, "stacking": { "mode": "normal" } }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "sum", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 20, "type": "table", "title": "Top LAN devices with DNS blocked",
      "description": "The smoking-gun panel for your DNS troubleshooting. Each row is an internal IP whose DNS query was denied by the firewall. If a device is trying to use a DNS server the BGW blocks (e.g. you set 1.1.1.1 manually but BGW intercepts DNS), it shows up here.",
      "gridPos": { "x": 0, "y": 40, "w": 12, "h": 10 },
      "datasource": { "type": "loki", "uid": "unhealthy-loki" },
      "targets": [{ "refId": "A",
        "expr": "topk(20, sum by (src) (count_over_time({host=\"att-router\"} |~ \"hook=FORWARD\" |~ \"DPT=53|DPT=853\" |~ \"$lan_filter\" | regexp `SRC=(?P<src>[^ ]+)` [$__range])))",
        "datasource": { "type": "loki", "uid": "unhealthy-loki" },
        "instant": true, "format": "table" }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "src": "LAN Source IP", "Value": "DNS drops" } } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [{ "field": "DNS drops", "desc": true }] } }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [
        { "matcher": { "id": "byName", "options": "DNS drops" },
          "properties": [
            { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
            { "id": "custom.align", "value": "right" },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 100 }
            ] } }
          ] }
      ] },
      "options": { "showHeader": true }
    },
    {
      "id": 21, "type": "table", "title": "Top external DNS servers being blocked",
      "description": "Which upstream resolvers your LAN is trying to reach but getting denied. Common public resolvers (8.8.8.8 Google, 1.1.1.1 Cloudflare, 9.9.9.9 Quad9) appearing here means the BGW is intercepting outbound DNS — usually because of an AT&T DNS hijack feature or strict DPI rules. If your LAN device set its DNS to one of these and the router blocks it, that device fails resolution silently.",
      "gridPos": { "x": 12, "y": 40, "w": 12, "h": 10 },
      "datasource": { "type": "loki", "uid": "unhealthy-loki" },
      "targets": [{ "refId": "A",
        "expr": "topk(20, sum by (dst) (count_over_time({host=\"att-router\"} |~ \"hook=FORWARD\" |~ \"DPT=53|DPT=853\" |~ \"$lan_filter\" | regexp `DST=(?P<dst>[^ ]+)` [$__range])))",
        "datasource": { "type": "loki", "uid": "unhealthy-loki" },
        "instant": true, "format": "table" }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "dst": "Blocked DNS Server", "Value": "Attempts" } } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [{ "field": "Attempts", "desc": true }] } }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [
        { "matcher": { "id": "byName", "options": "Attempts" },
          "properties": [
            { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
            { "id": "custom.align", "value": "right" }
          ] }
      ] },
      "options": { "showHeader": true }
    },
    {
      "id": 30, "type": "table", "title": "DNS drop reasons (why the BGW killed it)",
      "description": "POLICY-* = a configured firewall rule denied the packet. IP-SRC = anti-spoofing failure (source IP didn't match the interface it came in on — e.g. wrong-subnet device, mis-routed traffic). The reason vocabulary tells you whether to look at firewall rules or device subnet config.",
      "gridPos": { "x": 0, "y": 50, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "unhealthy-loki" },
      "targets": [{ "refId": "A",
        "expr": "topk(15, sum by (reason) (count_over_time({host=\"att-router\"} |~ \"DPT=53|DPT=853\" |~ \"$lan_filter\" | regexp `reason=(?P<reason>[^ ]+)` [$__range])))",
        "datasource": { "type": "loki", "uid": "unhealthy-loki" },
        "instant": true, "format": "table" }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "reason": "Reason", "Value": "Hits" } } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [{ "field": "Hits", "desc": true }] } }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [
        { "matcher": { "id": "byName", "options": "Hits" },
          "properties": [
            { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
            { "id": "custom.align", "value": "right" }
          ] }
      ] },
      "options": { "showHeader": true }
    },
    {
      "id": 31, "type": "table", "title": "Protocol breakdown",
      "description": "UDP/53 vs TCP/53 vs TCP/853 (DoT). Most resolvers use UDP first; TCP fallback usually means a large response or a failure mode. DoT (port 853) means the device is trying encrypted DNS — common with Apple devices and modern OSes. If only DoT is blocked, BGW may have explicit DoT denial.",
      "gridPos": { "x": 12, "y": 50, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "unhealthy-loki" },
      "targets": [{ "refId": "A",
        "expr": "sum by (proto, dpt) (count_over_time({host=\"att-router\"} |~ \"DPT=53|DPT=853\" |~ \"$lan_filter\" | regexp `PROTO=(?P<proto>[^ ]+)` | regexp `DPT=(?P<dpt>[^ ]+)` [$__range]))",
        "datasource": { "type": "loki", "uid": "unhealthy-loki" },
        "instant": true, "format": "table" }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "proto": "Protocol", "dpt": "Port", "Value": "Hits" } } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [{ "field": "Hits", "desc": true }] } }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [
        { "matcher": { "id": "byName", "options": "Hits" },
          "properties": [
            { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
            { "id": "custom.align", "value": "right" }
          ] }
      ] },
      "options": { "showHeader": true }
    },
    {
      "id": 40, "type": "logs", "title": "Recent DNS drops (live tail)",
      "description": "Raw firewall events for any packet to/from port 53 or 853. Filter by LAN IP using the variable above to focus on a specific device's failures.",
      "gridPos": { "x": 0, "y": 58, "w": 24, "h": 14 },
      "datasource": { "type": "loki", "uid": "unhealthy-loki" },
      "targets": [{ "refId": "A",
        "expr": "{host=\"att-router\"} |~ \"DPT=53|DPT=853\" |~ \"$lan_filter\"",
        "datasource": { "type": "loki", "uid": "unhealthy-loki" },
        "maxLines": 1000 }],
      "options": {
        "showTime": true, "showLabels": false, "showCommonLabels": false,
        "wrapLogMessage": true, "prettifyLogMessage": false,
        "enableLogDetails": true, "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
