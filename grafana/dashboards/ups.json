{
  "title": "UPS / Power",
  "uid": "unhealthy-ups",
  "tags": [
    "unraid",
    "unhealthy",
    "ups",
    "power"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "rate",
        "type": "textbox",
        "label": "Rate ($/kWh)",
        "query": "0.167",
        "current": {
          "text": "0.167",
          "value": "0.167"
        },
        "options": [
          {
            "text": "0.167",
            "value": "0.167",
            "selected": true
          }
        ],
        "hide": 0
      },
      {
        "name": "ups_nominal_w",
        "type": "textbox",
        "label": "UPS nominal W",
        "query": "600",
        "current": {
          "text": "600",
          "value": "600"
        },
        "options": [
          {
            "text": "600",
            "value": "600",
            "selected": true
          }
        ],
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Output Load",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "unhealthy-prom"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "apcups_load_percent",
          "datasource": {
            "type": "prometheus",
            "uid": "unhealthy-prom"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
