{
  "title": "UPS / Power",
  "uid": "unhealthy-ups",
  "tags": ["unraid", "unhealthy", "ups", "power"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "gauge", "title": "Output Load",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A", "expr": "apcups_load_percent", "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "decimals": 1,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 70 },
          { "color": "red", "value": 90 }
        ] } }, "overrides": [] },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true }
    },
    {
      "id": 2, "type": "stat", "title": "Output Voltage",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A", "expr": "apcups_output_voltage_volts", "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } }],
      "fieldConfig": { "defaults": { "unit": "volt", "decimals": 1,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 105 },
          { "color": "green", "value": 110 },
          { "color": "yellow", "value": 126 },
          { "color": "red", "value": 130 }
        ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" }
    },
    {
      "id": 3, "type": "stat", "title": "Input Voltage",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A", "expr": "apcups_input_voltage_volts", "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } }],
      "fieldConfig": { "defaults": { "unit": "volt", "decimals": 1,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 105 },
          { "color": "green", "value": 110 },
          { "color": "yellow", "value": 126 },
          { "color": "red", "value": 130 }
        ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" }
    },
    {
      "id": 4, "type": "gauge", "title": "Battery Charge",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A", "expr": "apcups_battery_charge_percent", "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 50 },
          { "color": "green", "value": 80 }
        ] } }, "overrides": [] },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true }
    },
    {
      "id": 5, "type": "stat", "title": "Runtime Left",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A", "expr": "apcups_runtime_seconds", "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } }],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 300 },
          { "color": "green", "value": 600 }
        ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 6, "type": "stat", "title": "UPS Link",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A", "expr": "apcups_scrape_success", "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0,
        "mappings": [
          { "type": "value", "options": { "0": { "text": "NO LINK", "color": "red" }, "1": { "text": "OK", "color": "green" } } }
        ],
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null },
          { "color": "green", "value": 1 }
        ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 7, "type": "timeseries", "title": "Output Load",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A", "expr": "apcups_load_percent", "legendFormat": "load", "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8, "type": "timeseries", "title": "Input / Output Voltage",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [
        { "refId": "A", "expr": "apcups_input_voltage_volts", "legendFormat": "input", "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } },
        { "refId": "B", "expr": "apcups_output_voltage_volts", "legendFormat": "output", "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } }
      ],
      "fieldConfig": { "defaults": { "unit": "volt", "decimals": 1,
        "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 9, "type": "stat", "title": "Output Current",
      "gridPos": { "x": 0, "y": 13, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A", "expr": "apcups_output_current_amps", "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } }],
      "fieldConfig": { "defaults": { "unit": "amp", "decimals": 2 }, "overrides": [] },
      "options": { "colorMode": "none", "graphMode": "area", "textMode": "value" }
    },
    {
      "id": 10, "type": "stat", "title": "Output Frequency",
      "gridPos": { "x": 6, "y": 13, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A", "expr": "apcups_output_frequency_hertz", "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } }],
      "fieldConfig": { "defaults": { "unit": "hertz", "decimals": 2 }, "overrides": [] },
      "options": { "colorMode": "none", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 11, "type": "stat", "title": "Battery Voltage",
      "gridPos": { "x": 12, "y": 13, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A", "expr": "apcups_battery_voltage_volts", "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } }],
      "fieldConfig": { "defaults": { "unit": "volt", "decimals": 2 }, "overrides": [] },
      "options": { "colorMode": "none", "graphMode": "area", "textMode": "value" }
    },
    {
      "id": 12, "type": "stat", "title": "Last Poll Age",
      "gridPos": { "x": 18, "y": 13, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "unhealthy-prom" },
      "targets": [{ "refId": "A", "expr": "apcups_scrape_age_seconds", "datasource": { "type": "prometheus", "uid": "unhealthy-prom" } }],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 90 },
          { "color": "red", "value": 300 }
        ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" }
    }
  ]
}
