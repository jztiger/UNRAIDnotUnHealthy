      "panels": []
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Cost / hour (now)",
      "description": "Current UPS real-power load \u00d7 your rate. Estimate from load% \u00d7 nominal W (~\u00b110%).",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 4,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "unhealthy-prom"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "apcups_load_percent / 100 * $ups_nominal_w / 1000 * $rate",
