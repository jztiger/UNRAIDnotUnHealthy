#!/usr/bin/env bash
# Remap the in-image `unhealthy` user/group to match host PUID/PGID, and
# fix ownership of the persistent volumes. Runs once on container start,
# before s6 brings up any longrun service.
#
# Unraid convention: PUID=99 (nobody), PGID=100 (users).
# Skip silently if PUID/PGID are unset — defaults stay in place.
#
# Implementation notes:
#
# 1. We edit /etc/passwd and /etc/group directly via sed instead of using
#    usermod / groupmod. usermod prints "user is currently used" as a
#    WARNING (exit 0) and refuses to change the uid when any process is
#    using the user — which can happen even at init time on s6-overlay v3
#    (helper processes spawned by fix-attrs / oneshot-runner). With usermod
#    silently no-op'ing, the remap appears to succeed but the running
#    container keeps uid 999, breaking ownership on bind-mounted volumes.
#
# 2. The /etc/passwd line stores the user's primary gid in field 4. `id -g`
#    reads from passwd, NOT from /etc/group. So we MUST set both uid and
#    gid together in the passwd sed — otherwise `id -g` lags the gid
#    rename in /etc/group, and chown will use a stale group.
set -e

if [[ -z "${PUID:-}" && -z "${PGID:-}" ]]; then
  exit 0
fi

CURRENT_UID="$(id -u unhealthy)"
CURRENT_GID="$(id -g unhealthy)"

TARGET_UID="${PUID:-${CURRENT_UID}}"
TARGET_GID="${PGID:-${CURRENT_GID}}"

# Rename the `unhealthy` GROUP to the target gid (e.g. 999 → 100).
if [[ "${TARGET_GID}" != "${CURRENT_GID}" ]]; then
  sed -i -E "s|^unhealthy:x:${CURRENT_GID}:|unhealthy:x:${TARGET_GID}:|" /etc/group
fi

# Update the `unhealthy` USER's uid AND primary gid in one pass.
sed -i -E \
  "s|^unhealthy:x:${CURRENT_UID}:${CURRENT_GID}:|unhealthy:x:${TARGET_UID}:${TARGET_GID}:|" \
  /etc/passwd

echo "[init-puid] unhealthy is now $(id unhealthy)"

# Persistent volumes — chown to the (now remapped) unhealthy uid:gid so
# Prometheus, Grafana, Loki, etc. can read+write through the bind mount.
chown -R "${TARGET_UID}:${TARGET_GID}" \
  /var/lib/prometheus \
  /var/lib/grafana \
  /var/lib/loki \
  /var/log/grafana 2>/dev/null || true
