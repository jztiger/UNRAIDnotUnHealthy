#!/usr/bin/env python3
"""bgw-nat-scraper — poll the BGW320 NAT translation table at
/cgi-bin/nattable.ha and expose entry counts as Prometheus metrics.

Used to detect conntrack pressure on the BGW (e.g. heavy Usenet pulls
opening many concurrent connections). The page requires admin auth, so
the operator must set BGW_DEVICE_ACCESS_CODE in the environment — if
unset, the service stays alive but reports scrape_success=0 so the lack
of data is visible on the dashboard rather than silent.

Stdlib only.
"""
import hashlib
import http.cookiejar
import http.server
import os
import re
import socketserver
import sys
import threading
import time
import urllib.parse
import urllib.request


BGW_HOST = os.environ.get("BGW_HOST", "192.168.1.254")
BGW_CODE = os.environ.get("BGW_DEVICE_ACCESS_CODE", "").strip()
LISTEN_ADDR = os.environ.get("BGW_NAT_SCRAPER_ADDR", "127.0.0.1")
LISTEN_PORT = int(os.environ.get("BGW_NAT_SCRAPER_PORT", "9145"))
POLL_INTERVAL = int(os.environ.get("BGW_NAT_POLL_INTERVAL", "60"))
TOP_N_LAN = int(os.environ.get("BGW_NAT_TOP_N_LAN", "10"))


def log(msg: str) -> None:
    print(f"bgw-nat-scraper: {msg}", file=sys.stderr, flush=True)


_state = {
    "last_attempt": 0.0,
    "last_success": 0.0,
    "duration": 0.0,
    "ok": False,
    "err": "",
    "tcp": 0, "udp": 0, "icmp": 0, "total": 0,
    "by_lan": {},
}
_lock = threading.Lock()


def _login_and_fetch_nat() -> str:
    """Authenticate against the BGW and return the NAT table HTML body."""
    cj = http.cookiejar.CookieJar()
    opener = urllib.request.build_opener(urllib.request.HTTPCookieProcessor(cj))

    # Visit root once so the BGW issues a SessionID cookie before login.
    opener.open(f"http://{BGW_HOST}/", timeout=15).read()

    r = opener.open(f"http://{BGW_HOST}/cgi-bin/login.ha", timeout=15)
    html = r.read().decode("utf-8", errors="replace")
    m = re.search(r'name=["\']?nonce["\']?\s+value=["\']([^"\']+)["\']', html)
    if not m:
        raise RuntimeError("no nonce on login page")
    nonce = m.group(1)

    # BGW JS does: hashpassword = md5(access_code + nonce) hex.
    hashpw = hashlib.md5((BGW_CODE + nonce).encode()).hexdigest()
    body = urllib.parse.urlencode({
        "nonce": nonce,
        "password": "*" * len(BGW_CODE),
        "hashpassword": hashpw,
        "Continue": "Continue",
    }).encode()
    req = urllib.request.Request(
        f"http://{BGW_HOST}/cgi-bin/login.ha", data=body, method="POST")
    opener.open(req, timeout=15).read()

    r = opener.open(f"http://{BGW_HOST}/cgi-bin/nattable.ha", timeout=60)
    page = r.read().decode("utf-8", errors="replace")
    if "<title>Login" in page[:1000]:
        raise RuntimeError("auth failed (still on login page)")
    return page


_PROTO_SPLIT = re.compile(r"\bipv4\s+(?=tcp|udp|icmp)\b")
_LAN_IP = re.compile(r"^192\.168\.\d{1,3}\.\d{1,3}$")


def _parse_nat(html: str):
    text = re.sub(r"<[^>]+>", " ", html)
    text = re.sub(r"\s+", " ", text).strip()
    counts = {"tcp": 0, "udp": 0, "icmp": 0}
    by_lan: dict[str, int] = {}
    for raw in _PROTO_SPLIT.split(text):
        toks = raw.split()
        if not toks or toks[0] not in counts:
            continue
        counts[toks[0]] += 1
        for t in toks[1:]:
            if _LAN_IP.match(t):
                by_lan[t] = by_lan.get(t, 0) + 1
                break
    return counts, by_lan


def _scrape_loop() -> None:
    while True:
        if not BGW_CODE:
            with _lock:
                _state["err"] = "BGW_DEVICE_ACCESS_CODE not set"
                _state["ok"] = False
                _state["last_attempt"] = time.time()
            time.sleep(POLL_INTERVAL)
            continue
        t0 = time.time()
        try:
            page = _login_and_fetch_nat()
            counts, by_lan = _parse_nat(page)
            with _lock:
                _state.update(counts)
                _state["total"] = sum(counts.values())
                _state["by_lan"] = by_lan
                _state["ok"] = True
                _state["err"] = ""
                _state["last_success"] = time.time()
                _state["duration"] = time.time() - t0
                _state["last_attempt"] = time.time()
        except Exception as e:
            log(f"scrape failed: {e}")
            with _lock:
                _state["ok"] = False
                _state["err"] = str(e)[:200]
                _state["duration"] = time.time() - t0
                _state["last_attempt"] = time.time()
        time.sleep(POLL_INTERVAL)


def _render_metrics() -> bytes:
    with _lock:
        s = dict(_state)
        by_lan = dict(s["by_lan"])
    age = time.time() - s["last_success"] if s["last_success"] else -1.0
    lines = [
        "# HELP bgw_nat_scrape_success 1 if last scrape attempt succeeded",
        "# TYPE bgw_nat_scrape_success gauge",
        f"bgw_nat_scrape_success {1 if s['ok'] else 0}",
        "# HELP bgw_nat_scrape_duration_seconds Wall time of last scrape attempt",
        "# TYPE bgw_nat_scrape_duration_seconds gauge",
        f"bgw_nat_scrape_duration_seconds {s['duration']:.6f}",
        "# HELP bgw_nat_scrape_age_seconds Seconds since last successful scrape (-1 if never)",
        "# TYPE bgw_nat_scrape_age_seconds gauge",
        f"bgw_nat_scrape_age_seconds {age:.3f}",
        "# HELP bgw_nat_entries Active NAT/conntrack entries on the BGW by protocol",
        "# TYPE bgw_nat_entries gauge",
        f'bgw_nat_entries{{proto="tcp"}} {s["tcp"]}',
        f'bgw_nat_entries{{proto="udp"}} {s["udp"]}',
        f'bgw_nat_entries{{proto="icmp"}} {s["icmp"]}',
        "# HELP bgw_nat_entries_total Total active NAT/conntrack entries on the BGW",
        "# TYPE bgw_nat_entries_total gauge",
        f"bgw_nat_entries_total {s['total']}",
        "# HELP bgw_nat_entries_by_lan_ip Top-N NAT entries grouped by LAN source IP",
        "# TYPE bgw_nat_entries_by_lan_ip gauge",
    ]
    for ip, c in sorted(by_lan.items(), key=lambda kv: -kv[1])[:TOP_N_LAN]:
        lines.append(f'bgw_nat_entries_by_lan_ip{{lan_ip="{ip}"}} {c}')
    return ("\n".join(lines) + "\n").encode()


class _Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path != "/metrics":
            self.send_response(404); self.end_headers(); return
        body = _render_metrics()
        self.send_response(200)
        self.send_header("Content-Type", "text/plain; version=0.0.4")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, *_args, **_kw):
        pass  # suppress access log noise


class _ThreadingServer(socketserver.ThreadingMixIn, http.server.HTTPServer):
    daemon_threads = True


def main() -> int:
    if not BGW_CODE:
        log("BGW_DEVICE_ACCESS_CODE not set — scraper will idle, "
            "scrape_success will be 0 until configured")
    threading.Thread(target=_scrape_loop, daemon=True).start()
    srv = _ThreadingServer((LISTEN_ADDR, LISTEN_PORT), _Handler)
    log(f"listening on {LISTEN_ADDR}:{LISTEN_PORT}, "
        f"polling http://{BGW_HOST} every {POLL_INTERVAL}s")
    srv.serve_forever()
    return 0


if __name__ == "__main__":
    sys.exit(main())
