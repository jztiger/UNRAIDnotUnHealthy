#!/usr/bin/env python3
"""bgw-syslog-forwarder — receive raw UDP log lines from the AT&T BGW320
router and push them directly to the local Loki HTTP API.

The BGW320 emits log lines without the RFC3164/5424 <priority> framing
that Alloy's loki.source.syslog requires (verified 2026-05-03 — every
packet was rejected with 'invalid framing. first byte: "P"'). Alloy v1.5.0
also doesn't include the experimental syslog_format="raw" mode or
otelcol.receiver.udplog. So this 30-line listener fills the gap until
Alloy is upgraded.

Each UDP datagram becomes one Loki log line with two static labels:
  host = att-router
  job  = syslog_remote
matching the labelling shape we'd have used via Alloy. Grafana queries
keyed on {host="att-router"} work the same way.
"""
import json
import os
import signal
import socket
import sys
import time
import urllib.error
import urllib.request

LISTEN_PORT = int(os.environ.get("BGW_LISTEN_PORT", "1514"))
LOKI_URL = os.environ.get("LOKI_URL", "http://127.0.0.1:3100/loki/api/v1/push")
LABELS = {"host": "att-router", "job": "syslog_remote"}


def log(msg: str) -> None:
    print(f"bgw-syslog-forwarder: {msg}", file=sys.stderr, flush=True)


def push_to_loki(line: str) -> None:
    body = json.dumps({
        "streams": [{
            "stream": LABELS,
            "values": [[str(time.time_ns()), line]],
        }],
    }).encode()
    req = urllib.request.Request(
        LOKI_URL,
        data=body,
        method="POST",
        headers={"Content-Type": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=5) as resp:
            if resp.status >= 300:
                log(f"loki returned {resp.status}: {resp.read()[:200]!r}")
    except (urllib.error.URLError, OSError) as e:
        # Loki may briefly be unavailable on container start — log and drop.
        # We don't queue because the BGW will keep sending; missed packets
        # during a 5-second Loki outage aren't worth complicating this.
        log(f"loki push failed: {e}")


def main() -> int:
    signal.signal(signal.SIGTERM, lambda *_: sys.exit(0))
    signal.signal(signal.SIGINT, lambda *_: sys.exit(0))

    sock = socket.socket(socket.AF_INET6, socket.SOCK_DGRAM)
    # Allow v4-mapped clients (the BGW sends IPv4) on the same v6 socket.
    sock.setsockopt(socket.IPPROTO_IPV6, socket.IPV6_V6ONLY, 0)
    sock.bind(("::", LISTEN_PORT))
    log(f"listening on UDP/{LISTEN_PORT}, forwarding to {LOKI_URL}")

    while True:
        data, _addr = sock.recvfrom(65535)
        line = data.decode("utf-8", errors="replace").rstrip("\r\n")
        if not line:
            continue
        push_to_loki(line)


if __name__ == "__main__":
    sys.exit(main())
