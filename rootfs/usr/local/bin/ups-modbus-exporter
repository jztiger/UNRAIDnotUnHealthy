#!/usr/bin/env python3
"""ups-modbus-exporter — poll an APC Smart-UPS over Modbus TCP and expose
selected measurements as Prometheus metrics.

The APC SmartConnect / Smart-UPS Modbus TCP interface (enable on the UPS LCD:
Advanced -> Configuration -> Modbus, read-only) serves holding registers that
include data the USB/HID interface does NOT expose -- notably output load %,
output voltage, and input voltage. apcupsd over USB stays the source of truth
for graceful shutdown; this exporter is metrics-only.

The UPS accepts ONE Modbus connection at a time, so we poll on a background
thread (fresh connect + explicit close per cycle) and serve the cached result
from the HTTP handler -- never read the device synchronously inside a scrape.
On any failure the service stays alive and reports apcups_scrape_success=0 so
the dashboard surfaces the gap rather than going silent (same idle-visible
pattern as bgw-nat-scraper).

Register map (function 3 / read holding registers, unit id 1), from the NUT
apc_modbus driver; scale = divide:
  128-129 runtime          UINT32 seconds (no scale)
  130     battery SoC      /512  -> percent
  131     battery voltage  INT   /32   -> volts
  136     output load      /256  -> percent
  140     output current   /32   -> amps
  142     output voltage   /64   -> volts
  144     output frequency /128  -> hertz
  151     input voltage    /64   -> volts
Registers reading 0xFFFF are treated as "unavailable" and not emitted (which
fields report can change with line/battery state).

Stdlib only.
"""
import http.server
import os
import socket
import socketserver
import struct
import sys
import threading
import time

HOST = os.environ.get("UPS_MODBUS_HOST", "192.168.1.168").strip()
PORT = int(os.environ.get("UPS_MODBUS_PORT", "502"))
UNIT = int(os.environ.get("UPS_MODBUS_UNIT_ID", "1"))
LISTEN_ADDR = os.environ.get("UPS_MODBUS_EXPORTER_ADDR", "127.0.0.1")
LISTEN_PORT = int(os.environ.get("UPS_MODBUS_EXPORTER_PORT", "9686"))
POLL_INTERVAL = int(os.environ.get("UPS_MODBUS_POLL_INTERVAL", "30"))

BLOCK_START = 128
BLOCK_QTY = 24  # registers 128..151 inclusive
UNAVAIL = 0xFFFF


def log(msg: str) -> None:
    print(f"ups-modbus-exporter: {msg}", file=sys.stderr, flush=True)


_state = {"last_success": 0.0, "duration": 0.0, "ok": False, "err": "", "metrics": {}}
_lock = threading.Lock()


def _recv_exact(sock: socket.socket, n: int) -> bytes:
    buf = b""
    while len(buf) < n:
        chunk = sock.recv(n - len(buf))
        if not chunk:
            raise RuntimeError("connection closed mid-response")
        buf += chunk
    return buf


def _read_block() -> list:
    """Open a fresh connection, read the holding-register block, return 24 u16.

    The card allows only one concurrent connection, so we always connect and
    close per poll. Raises on any transport/protocol error.
    """
    pdu = struct.pack(">BHH", 3, BLOCK_START, BLOCK_QTY)
    mbap = struct.pack(">HHHB", 1, 0, len(pdu) + 1, UNIT)
    sock = socket.create_connection((HOST, PORT), timeout=5)
    try:
        sock.settimeout(5)
        sock.sendall(mbap + pdu)
        # MBAP(7) + function(1) + bytecount(1), then the register payload
        hdr = _recv_exact(sock, 9)
        fc = hdr[7]
        if fc & 0x80:  # exception response
            raise RuntimeError(f"modbus exception fc=0x{fc:02x} code={hdr[8]}")
        data = _recv_exact(sock, hdr[8])
    finally:
        sock.close()
    if len(data) < BLOCK_QTY * 2:
        raise RuntimeError(f"short read: {len(data)} bytes")
    return list(struct.unpack(">%dH" % BLOCK_QTY, data[: BLOCK_QTY * 2]))


def _decode(regs: list) -> dict:
    def u(addr):
        return regs[addr - BLOCK_START]

    m = {}
    hi, lo = u(128), u(129)
    if not (hi == UNAVAIL and lo == UNAVAIL):
        m["apcups_runtime_seconds"] = float((hi << 16) | lo)
    if u(130) != UNAVAIL:
        m["apcups_battery_charge_percent"] = u(130) / 512.0
    if u(131) != UNAVAIL:
        m["apcups_battery_voltage_volts"] = struct.unpack(">h", struct.pack(">H", u(131)))[0] / 32.0
    if u(136) != UNAVAIL:
        m["apcups_load_percent"] = u(136) / 256.0
    if u(140) != UNAVAIL:
        m["apcups_output_current_amps"] = u(140) / 32.0
    if u(142) != UNAVAIL:
        m["apcups_output_voltage_volts"] = u(142) / 64.0
    if u(144) != UNAVAIL:
        m["apcups_output_frequency_hertz"] = u(144) / 128.0
    if u(151) != UNAVAIL:
        m["apcups_input_voltage_volts"] = u(151) / 64.0
    return m


def _scrape_loop() -> None:
    while True:
        t0 = time.time()
        try:
            metrics = _decode(_read_block())
            with _lock:
                _state["metrics"] = metrics
                _state["ok"] = True
                _state["err"] = ""
                _state["last_success"] = time.time()
                _state["duration"] = time.time() - t0
        except Exception as e:  # noqa: BLE001 - stay alive, surface via scrape_success
            log(f"scrape failed: {e}")
            with _lock:
                _state["ok"] = False
                _state["err"] = str(e)[:200]
                _state["duration"] = time.time() - t0
        time.sleep(POLL_INTERVAL)


_HELP = {
    "apcups_runtime_seconds": "Estimated battery runtime remaining",
    "apcups_battery_charge_percent": "Battery state of charge (percent)",
    "apcups_battery_voltage_volts": "Battery DC voltage",
    "apcups_load_percent": "Output load (real power) as percent of capacity",
    "apcups_output_current_amps": "Output current",
    "apcups_output_voltage_volts": "Output AC voltage",
    "apcups_output_frequency_hertz": "Output frequency",
    "apcups_input_voltage_volts": "Input (line) AC voltage",
}


def _render_metrics() -> bytes:
    with _lock:
        s = dict(_state)
        metrics = dict(s["metrics"])
    age = time.time() - s["last_success"] if s["last_success"] else -1.0
    lines = [
        "# HELP apcups_scrape_success 1 if the last Modbus poll succeeded",
        "# TYPE apcups_scrape_success gauge",
        f"apcups_scrape_success {1 if s['ok'] else 0}",
        "# HELP apcups_scrape_duration_seconds Wall time of the last Modbus poll",
        "# TYPE apcups_scrape_duration_seconds gauge",
        f"apcups_scrape_duration_seconds {s['duration']:.6f}",
        "# HELP apcups_scrape_age_seconds Seconds since last successful poll (-1 if never)",
        "# TYPE apcups_scrape_age_seconds gauge",
        f"apcups_scrape_age_seconds {age:.3f}",
    ]
    for name, val in metrics.items():
        if name in _HELP:
            lines.append(f"# HELP {name} {_HELP[name]}")
        lines.append(f"# TYPE {name} gauge")
        lines.append(f"{name} {val:.4f}")
    return ("\n".join(lines) + "\n").encode()


class _Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path != "/metrics":
            self.send_response(404)
            self.end_headers()
            return
        body = _render_metrics()
        self.send_response(200)
        self.send_header("Content-Type", "text/plain; version=0.0.4")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, *_args, **_kw):
        pass  # suppress access-log noise


class _ThreadingServer(socketserver.ThreadingMixIn, http.server.HTTPServer):
    daemon_threads = True


def main() -> int:
    if not HOST:
        log("UPS_MODBUS_HOST not set -- exporter will idle, scrape_success=0")
    threading.Thread(target=_scrape_loop, daemon=True).start()
    srv = _ThreadingServer((LISTEN_ADDR, LISTEN_PORT), _Handler)
    log(f"listening on {LISTEN_ADDR}:{LISTEN_PORT}, polling "
        f"{HOST}:{PORT} unit {UNIT} every {POLL_INTERVAL}s")
    srv.serve_forever()
    return 0


if __name__ == "__main__":
    sys.exit(main())
