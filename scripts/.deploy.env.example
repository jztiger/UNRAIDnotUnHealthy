# Copy to scripts/.deploy.env and fill in. The .env file is gitignored.
# Used by scripts/deploy-to-unraid.sh.

# --- SSH ---
UNRAID_HOST=192.168.1.133
UNRAID_PORT=2222
UNRAID_USER=root
UNRAID_KEY=$HOME/.ssh/unraid_deploy

# --- Container ---
UNRAID_IP=192.168.1.100        # macvlan IP for the container
CONTAINER=unraidnotunhealthy
IMAGE=unraidnotunhealthy:dev

# --- Container env (mostly defaults; uncomment to override) ---
# TZ=America/Chicago
# PUID=1000
# PGID=1000
# PROMETHEUS_RETENTION=30d
# LOKI_RETENTION=14d
# GF_SECURITY_ADMIN_PASSWORD=admin

# --- Sonarr / Radarr exporter (leave blank to disable that exporter) ---
# SONARR_URL=http://192.168.1.21:8989
SONARR_API_KEY=
# RADARR_URL=http://192.168.1.6:7878
RADARR_API_KEY=
